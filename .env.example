# Pharos Cross-Chain RWA Distribution Oracle
# Environment Configuration

# Pharos Pacific Mainnet RPC
PHAROS_RPC_URL=https://rpc.pharos.xyz

# Pharos Atlantic Testnet RPC fallback
PHAROS_TESTNET_RPC_URL=https://atlantic.dplabs-internal.com

# Express server port
PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Optional cross-chain targets for the intelligent oracle.
# Can be an inline JSON array or a path such as ./destinations.example.json
ORACLE_DESTINATIONS=

# Local JSONL history file for trend/anomaly checks
ORACLE_HISTORY_PATH=.oracle-history.jsonl
